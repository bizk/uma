{
  "manifest_version": 3,
  "name": "AutoRondas 9-9",
  "version": "3.0.0",
  "description": "Auto-click y conteo de rondas/pacientes en Umasalud.",
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_title": "AutoRondas 9-9",
    "default_icon": {
      "16": "icons/icon_16.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://profesionales.umasalud.com/appointments*",
        "https://profesionales.umasalud.com/doctor*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}